{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "bun-types"],
    "paths": {
      "@/*": ["../../boboddy/src/*"],
      "@/lib/*": ["../../boboddy/src/lib/*"],
      "@/modules/*": ["../../boboddy/src/*"],
      "#boboddy/*": ["../../boboddy/src/*"]
    }
  },
  "include": ["src/**/*.ts", "tools/**/*.ts", "plugins/**/*.ts"],
  "exclude": ["node_modules"]
}
