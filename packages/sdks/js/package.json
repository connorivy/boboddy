{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@boboddy/sdk",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./definitions/steps": "./src/definitions/steps/index.ts",
    "./definitions/pipelines": "./src/definitions/pipelines/index.ts",
    "./definitions/advancement-policies": "./src/definitions/advancement-policies/index.ts",
    "./opencode-mcp": "./src/opencode-mcp.ts",
    "./jsonc": "./src/jsonc.ts",
    "./boboddy-config-parser": "./src/boboddy-config-parser.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/connorivy/boboddy"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "bun run script/build.ts",
    "link:local": "bun link",
    "test": "bun test test",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.90.10",
    "bun-types": "^1.3.12",
    "zod": "^4.3.6"
  }
}
