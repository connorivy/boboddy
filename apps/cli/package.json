{
  "name": "@boboddy/cli",
  "version": "0.0.0",
  "bin": {
    "boboddy": "bin/boboddy"
  },
  "files": [
    "README.md",
    "bin",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/connorivy/boboddy"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run script/build.ts",
    "build:dev": "bun run script/build.ts --dev",
    "link": "bun run script/link.ts",
    "link:local": "bun run build && bun link --global .",
    "test": "bun test test",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@boboddy/opencode-plugin": "workspace:*",
    "@boboddy/runtime-proxy": "workspace:*",
    "@boboddy/sdk": "workspace:*",
    "@boboddy/worker": "workspace:*",
    "@devcontainers/cli": "0.86.0",
    "@opencode-ai/sdk": "1.14.34",
    "ajv": "^8.20.0",
    "better-auth": "^1.6.7",
    "dotenv": "^16.0.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.2",
    "uuid": "^13.0.0",
    "yargs": "^17.7.2",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.33",
    "bun-types": "^1.3.12"
  }
}
