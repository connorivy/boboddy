{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@boboddy/sdk": ["./src/index.ts"],
      "@boboddy/sdk/*": ["./src/*"]
