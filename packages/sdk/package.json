{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@boboddy/sdk",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "bun": "./src/client.ts",
      "import": "./dist/client.js"
    },
    "./define-step": {
      "types": "./dist/define-step.d.ts",
      "bun": "./src/define-step.ts",
      "import": "./dist/define-step.js"
    },
    "./step-definitions-client": {
      "types": "./dist/step-definitions-client.d.ts",
      "bun": "./src/step-definitions-client.ts",
      "import": "./dist/step-definitions-client.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "bun run script/build.ts",
    "declarations": "bun run script/declarations.ts",
    "test": "bun test test",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.90.10",
    "bun-types": "^1.3.12",
    "zod": "^4.3.6"
  }
}
