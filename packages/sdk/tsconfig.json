{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@/*": ["../../../apps/api/src/*"],
      "@boboddy/api/*": ["../../../apps/api/src/*"],
      "@boboddy/containers": ["../../containers/src/index.ts"],
      "@boboddy/containers/*": ["../../containers/src/*"],
      "@boboddy/opencode": ["../../ai/opencode/src/index.ts"],
      "@boboddy/opencode/*": ["../../ai/opencode/src/*"],
      "@boboddy/sdk": ["./src/index.ts"],
      "@boboddy/sdk/*": ["./src/*"]
    },
    "types": ["bun-types", "node"]
  },
  "include": ["src/**/*.ts", "openapi-ts.config.ts"],
  "exclude": ["node_modules"]
}
