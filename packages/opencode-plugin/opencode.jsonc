{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "mcp": {
    "datadog": {
      "type": "local",
      "command": ["npx", "-y", "@winor30/mcp-server-datadog@1.7.0"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@0.0.68",
        "--headless",
        "--no-sandbox",
        "--executable-path",
        "/ms-playwright/chromium-1212/chrome-linux/chrome"
      ],
      "enabled": true
    },
    "pg_local": {
      "type": "local",
      "command": ["/opt/postgres-mcp/bin/postgres-mcp", "--access-mode=restricted"],
      "enabled": true
    }
  },
  "tools": {
    "datadog*": false,
    "tch*": true,
    "tch-fetch-company-admin-credentials*": false,
    "tch-fetch-company-ids*": false,
    "tch-fetch-user-credentials-by-emails*": false,
    "tch-fetch-user-ids-by-emails*": false,
    "playwright*": false,
    "pg_local*": false
  },
  "agent": {
    "ticket-investigation-agent": {
      "description": "Enrich ticket descriptions with evidence from Datadog logs and traces for users, companies, routes, and exception patterns.",
      "tools": {
        "datadog*": true,
        "tch*": true,
        "tch-fetch-company-admin-credentials*": true,
        "tch-fetch-company-ids*": true,
        "tch-fetch-user-ids-by-emails*": true,
        "pg_local*": true
      },
    },
    "web-repro-agent": {
      "description": "Reproduce user-facing frontend issues with Playwright from tests/e2e using already-installed headless Chromium, use the hosted frontend at the BASE_URL from services/frontend-web/application/.env, and resolve user and company identifiers with the provided custom tools.",
      "tools": {
        "tch*": true,
        "tch-fetch-company-admin-credentials*": true,
        "tch-fetch-company-ids*": true,
        "tch-fetch-user-credentials-by-emails*": true,
        "tch-fetch-user-ids-by-emails*": true,
        "playwright*": true
      },
    },
    "bug-auto-fix-agent": {
      "description": "Fix bug-related issues in the repository while using stable identifiers for users and companies when ticket context includes emails or company names.",
      "tools": {
        "tch*": true,
        "tch-fetch-company-admin-credentials*": true,
        "tch-fetch-company-ids*": true,
        "tch-fetch-user-ids-by-emails*": true
      },
    }
  }
}
