{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["bun-types", "node"],
    "noEmit": true,
    "paths": {
      "@boboddy/worker": ["./src/index.ts"],
      "@boboddy/worker/*": ["./src/*"]
