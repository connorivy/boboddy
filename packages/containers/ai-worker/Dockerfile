FROM mcr.microsoft.com/playwright/mcp:v0.0.68

USER root

ARG OPENCODE_NPM_PACKAGE=opencode-ai@1.3.3

ENV DEBIAN_FRONTEND=noninteractive
ENV OPENCODE_HOME=/home/node
ENV PATH=/usr/local/bin:${PATH}

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    awscli \
    bash \
    ca-certificates \
    curl \
    git \
    jq \
    openjdk-17-jdk-headless \
    openssh-client \
    python3 \
    python3-pip \
    python-is-python3 \
    ripgrep \
  && rm -rf /var/lib/apt/lists/*

RUN arch="$(dpkg --print-architecture)" \
  && case "$arch" in \
    amd64) session_manager_deb="https://s3.amazonaws.com/session-manager-downloads/plugin/latest/ubuntu_64bit/session-manager-plugin.deb" ;; \
    arm64) session_manager_deb="https://s3.amazonaws.com/session-manager-downloads/plugin/latest/ubuntu_arm64/session-manager-plugin.deb" ;; \
    *) echo "Unsupported architecture: $arch" && exit 1 ;; \
  esac \
  && curl -fsSL "$session_manager_deb" -o /tmp/session-manager-plugin.deb \
  && dpkg -i /tmp/session-manager-plugin.deb \
  && rm -f /tmp/session-manager-plugin.deb \
  && session-manager-plugin --version

RUN npm install --global "${OPENCODE_NPM_PACKAGE}" pnpm \
  && npm cache clean --force

RUN mkdir -p /opt/uv-python \
  && python3 -m pip install --no-cache-dir --break-system-packages uv \
  && UV_PYTHON_INSTALL_DIR=/opt/uv-python uv venv --python 3.12 /opt/postgres-mcp \
  && UV_PYTHON_INSTALL_DIR=/opt/uv-python uv pip install --python /opt/postgres-mcp/bin/python postgres-mcp \
  && ln -sf /opt/postgres-mcp/bin/postgres-mcp /usr/local/bin/postgres-mcp

RUN npm install -g @winor30/mcp-server-datadog@1.7.0

ENV UV_PYTHON_INSTALL_DIR=/opt/uv-python
ENV UV_TOOL_DIR=/opt/uv-tools
RUN uv tool install --python /opt/uv-python/cpython-3.12-linux-aarch64-gnu/bin/python3.12 playwright-trace-analyzer \
  && ln -sf /opt/uv-tools/playwright-trace-analyzer/bin/playwright-trace-analyzer /usr/local/bin/playwright-trace-analyzer \
  && chmod +x /opt/uv-tools/playwright-trace-analyzer/bin/playwright-trace-analyzer \
  && chown -R node:node /opt/uv-tools/

RUN mkdir -p /workspace "${OPENCODE_HOME}" \
  && chown -R node:node /workspace "${OPENCODE_HOME}"

COPY ai-worker/entrypoint.sh /usr/local/bin/opencode-entrypoint
RUN chmod +x /usr/local/bin/opencode-entrypoint

USER node
WORKDIR /workspace

EXPOSE 4096

ENTRYPOINT ["/usr/local/bin/opencode-entrypoint"]
CMD ["opencode", "serve", "--hostname", "0.0.0.0", "--port", "4096"]
