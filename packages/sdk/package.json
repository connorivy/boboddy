{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@boboddy/sdk",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./treaty": {
      "import": "./dist/treaty.js",
      "types": "./dist/treaty.d.ts"
    },
    "./define-step": {
      "bun": "./src/define-step.ts",
      "import": "./dist/define-step.js",
      "types": "./dist/define-step.d.ts"
    },
    "./step-definitions-client": {
      "import": "./dist/step-definitions-client.js",
      "types": "./dist/step-definitions-client.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run script/build.ts",
    "test": "bun test test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@boboddy/api": "workspace:*",
    "@boboddy/core": "workspace:*",
    "@elysiajs/eden": "^1.4.9",
    "elysia": "^1.4.28"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.90.10",
    "bun-types": "^1.3.12",
    "zod": "^4.3.6"
  }
}
